# PostgreSQL (local: use docker-compose postgres service)
DATABASE_URL="postgresql://wristos:wristos@localhost:5432/wristos?schema=public"

# API
PORT=4000
NODE_ENV=development

# Auth (placeholders for future JWT implementation)
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_EXPIRES_IN=7d

# Seed bootstrap (optional, for local dev)
SEED_TENANT_NAME=WristOS Demo Tenant
SEED_TENANT_SLUG=wristos-demo
SEED_ROLE_NAME=OWNER
SEED_USER_EMAIL=owner@wristos.local
SEED_USER_PASSWORD=ChangeMe123!
# Optional unique username for the demo owner (login: username or email)
# SEED_USER_USERNAME=

# Wrist Caviar tenant + Trejo users (seed creates/updates; override passwords in prod)
SEED_WRIST_CAVIAR_SLUG=wrist-caviar
# SEED_CESAR_PASSWORD=
# SEED_REGINA_PASSWORD=

# One-off: prisma/scripts/setup-wrist-caviar-users.ts (no seed, no deletes)
# WRIST_CAVIAR_TENANT_SLUG=wrist-caviar
# CESAR_PASSWORD=
# REGINA_PASSWORD=
# CESAR_EMAIL=
# REGINA_EMAIL=
# CESAR_USERNAME=
# REGINA_USERNAME=
