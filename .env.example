# PostgreSQL (local: use docker-compose postgres service)
DATABASE_URL="postgresql://wristos:wristos@localhost:5432/wristos?schema=public"

# API
PORT=4000
NODE_ENV=development

# Auth (placeholders for future JWT implementation)
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_EXPIRES_IN=7d

# Cloudinary (image upload for watch catalog photos + import file storage)
# Sign up at https://cloudinary.com — free tier is sufficient
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_UPLOAD_FOLDER=wristos/watches
# Optional override for data-onboarding import PDFs (default: <CLOUDINARY_UPLOAD_FOLDER>/imports)
# CLOUDINARY_IMPORT_FOLDER=wristos/imports

# Seed bootstrap (optional, for local dev)
SEED_TENANT_NAME=WristOS Demo Tenant
SEED_TENANT_SLUG=wristos-demo
SEED_ROLE_NAME=OWNER
SEED_USER_EMAIL=owner@wristos.local
SEED_USER_PASSWORD=ChangeMe123!

# Data onboarding — import file storage
# Provider: local | cloudinary
# - development/test: local is the default; set cloudinary (or leave unset with CLOUDINARY_* set) to use Cloudinary
# - production: Cloudinary is required (raw + type=authenticated). Missing CLOUDINARY_* throws at boot.
#   Emergency only: IMPORT_STORAGE_ALLOW_LOCAL_IN_PRODUCTION=true allows local disk on Railway (ephemeral — not durable).
IMPORT_STORAGE_PROVIDER=local
IMPORT_STORAGE_LOCAL_PATH=./storage/imports
# IMPORT_STORAGE_ALLOW_LOCAL_IN_PRODUCTION=false
IMPORT_MAX_FILE_SIZE_MB=25

# ─── PDF Invoice Importer (Sprint 3) ─────────────────────────────────────────
# Required for PDF AI extraction. Set provider=disabled or omit to leave off.
#
# Provider: claude | fake | disabled
DOCUMENT_EXTRACTION_PROVIDER=disabled

# --- Claude provider (required when DOCUMENT_EXTRACTION_PROVIDER=claude) -----
# NEVER commit real keys. Use Railway environment variables in production.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# --- Extraction tuning -------------------------------------------------------
# Request timeout in milliseconds (default 90000 = 90 s)
DOCUMENT_EXTRACTION_TIMEOUT_MS=90000

# Max output tokens per extraction request (default 8192; range 1024–16000)
# Effective watch capacity ≈ (DOCUMENT_EXTRACTION_MAX_TOKENS / 185) watches.
# Default 8192 supports ~44 watches safely. Increase for large invoices.
DOCUMENT_EXTRACTION_MAX_TOKENS=8192

# Maximum extracted watches per invoice (schema cap, default 50)
# Must be set consistently with DOCUMENT_EXTRACTION_MAX_TOKENS.
DOCUMENT_EXTRACTION_MAX_WATCHES=50

# Maximum PDF pages per document (default 50; 0 = unknown page count allowed)
DOCUMENT_EXTRACTION_MAX_PAGES=50
IMPORT_MAX_PDF_PAGES=50

# Minutes before a stuck PROCESSING session is recovered (default 15)
DOCUMENT_PROCESSING_STALE_TIMEOUT_MINUTES=15

# --- Fake provider (development / local testing only) -----------------------
# Provider=fake simulates AI responses without Anthropic cost.
# Blocked in NODE_ENV=production unless the override below is set.
# Scenarios: single-watch | multi-watch | no-watch | malformed | timeout |
#            truncated | prompt-injection | invoice-total-only |
#            accessory-lines | duplicate-serial
#DOCUMENT_EXTRACTION_FAKE_SCENARIO=single-watch
#DOCUMENT_EXTRACTION_ALLOW_FAKE_IN_PRODUCTION=false
