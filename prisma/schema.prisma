generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Enums ---

enum TenantStatus {
  ACTIVE
  INACTIVE
}

enum UserStatus {
  ACTIVE
  INVITED
  DISABLED
}

enum WatchOwnershipType {
  OWNED
  CONSIGNMENT
}

enum WatchStatus {
  AVAILABLE
  RESERVED
  SOLD
  IN_TRANSIT
  IN_SERVICE
}

enum DealStage {
  LEAD
  INTERESTED
  NEGOTIATING
  PENDING_PAYMENT
  CLOSED_WON
  CLOSED_LOST
}

enum PaymentStatus {
  PENDING
  PAID
  OVERDUE
}

enum PaymentMethod {
  TRANSFER
  CASH
  CARD
  OTHER
  BANCOS
  CESAR
}

enum CapitalAccount {
  CASH
  BANK
  CESAR_ACCOUNT
}

enum ClientInteractionType {
  CALL
  MESSAGE
  MEETING
  NOTE
}

enum AutomationRuleType {
  STALE_DEAL
  OVERDUE_PAYMENT
  AGING_INVENTORY
}

enum AutomationRunStatus {
  SUCCESS
  ERROR
}

enum WatchExpenseCategory {
  POLISHING
  REPAIR
  LINKS
  SHIPPING
  PARTS
  COMMISSIONS
  TRAVEL
}

enum OperatingExpenseCategory {
  GASOLINE
  TOLLS
  WATCHMAKER
  PARKING
  MEALS
  FLIGHTS
  TRAVEL
  MARKETING
  COMMISSIONS
  BANK_FEES
}

// --- Cuentas (AR/AP) ---

enum AccountEntryType {
  RECEIVABLE
  PAYABLE
}

enum AccountEntryStatus {
  OPEN
  PARTIAL
  PAID
  OVERDUE
  CANCELLED
}

enum AccountEntryCategory {
  SALE_BALANCE
  PURCHASE
  SERVICE
  COMMISSION
  REFUND
  LOAN
  OTHER
}

enum CounterpartyType {
  CLIENT
  SUPPLIER
  DEALER
  BROKER
  WORKSHOP
  LOGISTICS
  OTHER
}

enum Currency {
  MXN
  USD
}

enum TreasuryAccount {
  CASH
  BANK
  CESAR
}

enum TreasuryDirection {
  INFLOW
  OUTFLOW
}

enum AccountEntrySource {
  MANUAL
  DEAL_AUTO
}

enum StorefrontReservationStatus {
  PENDING    // Stripe session created, awaiting payment
  PAID       // checkout.session.completed webhook received
  CANCELLED  // session expired or explicitly cancelled
  PROCESSED  // admin reviewed and converted to deal
}


enum DataImportStatus {
  CREATED
  UPLOADING
  PROCESSING
  READY_FOR_REVIEW
  IMPORTING
  COMPLETED
  FAILED
  CANCELLED
}

enum DataImportFileStatus {
  UPLOADED
  PROCESSING
  PARSED
  FAILED
}

enum DataImportFileType {
  PDF
  XLSX
  CSV
  JSON
}

enum DataImportEntityType {
  INVENTORY
  CLIENTS
  DEALS
  PAYMENTS
  EXPENSES
  ACCOUNTS
  TREASURY
  INVESTORS
  RADAR
  UNKNOWN
}

enum DataImportRecordStatus {
  STAGED
  SELECTED
  SKIPPED
  IMPORTED
  FAILED
}

enum DataImportDuplicateStatus {
  NONE
  POSSIBLE_DUPLICATE
  CONFIRMED_DUPLICATE
}

enum DataImportEventType {
  SESSION_CREATED
  FILE_UPLOADED
  FILE_PROCESSING
  FILE_PARSED
  FILE_FAILED
  PROCESSING_STARTED
  PROCESSING_COMPLETED
  SESSION_FAILED
  SESSION_CANCELLED
  MAPPING_SAVED
  DRY_RUN_COMPLETED
  IMPORT_STARTED
  IMPORT_COMPLETED
  IMPORT_FAILED
  DOCUMENT_EXTRACTION_STARTED
  DOCUMENT_EXTRACTION_COMPLETED
  DOCUMENT_EXTRACTION_FAILED
  DOCUMENT_EXTRACTION_EDITED
}

// --- AI Market Radar ---

enum ChannelType {
  TELEGRAM
  WHATSAPP
  DISCORD
  SLACK
  EMAIL
  RSS
  OTHER
}

enum ImportStatus {
  PENDING
  PARSING
  CLASSIFYING
  COMPLETED
  FAILED
  PARTIAL
}

enum MarketListingIntent {
  SELL_OFFER
  BUY_REQUEST
  PRICE_SIGNAL
  GENERAL_INQUIRY
}

enum ReviewStatus {
  PENDING_REVIEW
  CONFIRMED
  DISMISSED
}

enum CatalogDataSource {
  MANUFACTURER_SPEC
  AFTERMARKET_GUIDE
  COMMUNITY_WIKI
  DEALER_NOTE
  AI_EXTRACTION
  MANUAL_ENTRY
}

enum ExtractionSource {
  EXPLICIT
  INFERRED
}

enum ClassificationStatus {
  PENDING
  COMPLETED
  FAILED
  SKIPPED_PREFILTER
  SKIPPED_MEDIA
  SKIPPED_SYSTEM
}

// --- Core (platform) ---

model Tenant {
  id        String       @id @default(cuid())
  name      String
  slug      String       @unique
  status    TenantStatus @default(ACTIVE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  roles              Role[]
  tenantUsers        TenantUser[]
  clients            Client[]
  clientPreferences  ClientPreference[]
  clientInteractions ClientInteraction[]
  watches            Watch[]
  watchImages        WatchImage[]
  watchExpenses      WatchExpense[]
  operatingExpenses  OperatingExpense[]
  deals              Deal[]
  payments           Payment[]
  automationRules    AutomationRule[]
  automationRuns     AutomationRun[]
  matchSuggestions   MatchSuggestion[]
  channels           Channel[]
  radarImports       RadarImport[]
  channelMessages    ChannelMessage[]
  contacts                 Contact[]
  marketListings           MarketListing[]
  investors                Investor[]
  investorContributions    InvestorContribution[]
  investorDistributions    InvestorDistribution[]
  accountEntries           AccountEntry[]
  accountPayments          AccountPayment[]
  treasuryEntries          TreasuryEntry[]
  storefrontReservations   StorefrontReservation[]
  dataImportSessions       DataImportSession[]
  dataImportFiles          DataImportFile[]
  dataImportRecords        DataImportRecord[]
  dataImportEvents         DataImportEvent[]

  @@index([slug])
  @@map("tenants")
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String?
  displayName  String?
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  tenantUsers        TenantUser[]
  dataImportSessions DataImportSession[] @relation("DataImportCreatedBy")

  @@map("users")
}

/// Role names are unique per tenant (e.g. OWNER, SALES, VIEWER).
model Role {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantUsers TenantUser[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("roles")
}

model TenantUser {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  roleId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@unique([tenantId, userId])
  @@index([userId])
  @@index([tenantId])
  @@map("tenant_users")
}

// --- WristOS domain (all tenant-scoped) ---

model Client {
  id          String    @id @default(cuid())
  tenantId    String
  name        String
  email       String?
  phone       String?
  notes       String?
  tags        String[]
  budgetRange String?
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant                 Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  deals                  Deal[]
  preferences            ClientPreference[]
  matchSuggestions       MatchSuggestion[]
  interactions           ClientInteraction[]
  radarContacts          Contact[]
  accountEntries         AccountEntry[]
  storefrontReservations StorefrontReservation[]

  @@index([tenantId])
  @@index([tenantId, email])
  @@index([tenantId, deletedAt])
  @@map("clients")
}

model ClientPreference {
  id              String   @id @default(cuid())
  tenantId        String
  clientId        String
  preferredBrands String[]
  preferredModels String[]
  budgetMin       Decimal? @db.Decimal(12, 2)
  budgetMax       Decimal? @db.Decimal(12, 2)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([tenantId, clientId])
  @@index([tenantId])
  @@index([tenantId, clientId])
  @@map("client_preferences")
}

model ClientInteraction {
  id         String                @id @default(cuid())
  tenantId   String
  clientId   String
  type       ClientInteractionType
  notes      String
  occurredAt DateTime
  createdAt  DateTime              @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, clientId])
  @@index([tenantId, occurredAt])
  @@map("client_interactions")
}

model Watch {
  id                         String             @id @default(cuid())
  tenantId                   String
  brand                      String
  model                      String
  reference                  String?
  serialNumber               String?
  imageUrl                   String?
  condition                  String
  cost                       Decimal            @db.Decimal(12, 2)
  priceMin                   Decimal            @db.Decimal(12, 2)
  priceMax                   Decimal            @db.Decimal(12, 2)
  ownershipType              WatchOwnershipType @default(OWNED)
  consignmentOwnerName       String?
  consignmentSplitPercentage Decimal?           @db.Decimal(5, 2)
  costCurrency               String?
  costOriginalAmount         Decimal?           @db.Decimal(12, 2)
  costExchangeRate           Decimal?           @db.Decimal(12, 6)
  status                     WatchStatus        @default(AVAILABLE)
  isPublished                Boolean            @default(false)
  publicSlug                 String?
  publicDescription          String?            @db.Text
  publicPrice                Decimal?           @db.Decimal(12, 2)
  reservationAmount          Decimal?           @db.Decimal(12, 2)
  deletedAt                  DateTime?
  createdAt                  DateTime           @default(now())
  updatedAt                  DateTime           @updatedAt

  tenant                 Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  deals                  Deal[]
  expenses               WatchExpense[]
  images                 WatchImage[]
  matchSuggestions       MatchSuggestion[]
  accountEntries         AccountEntry[]
  storefrontReservations StorefrontReservation[]

  @@unique([tenantId, publicSlug])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, isPublished])
  @@index([tenantId, deletedAt])
  @@map("watches")
}

model WatchImage {
  id        String    @id @default(cuid())
  tenantId  String
  watchId   String
  url       String
  altText   String?
  sortOrder Int       @default(0)
  isPrimary Boolean   @default(false)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  watch  Watch  @relation(fields: [watchId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, watchId])
  @@index([tenantId, watchId, sortOrder])
  @@index([tenantId, deletedAt])
  @@map("watch_images")
}

model WatchExpense {
  id        String               @id @default(cuid())
  tenantId  String
  watchId   String
  category  WatchExpenseCategory
  amount    Decimal              @db.Decimal(12, 2)
  notes     String?
  createdAt DateTime             @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  watch  Watch  @relation(fields: [watchId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([watchId])
  @@map("watch_expenses")
}

model Deal {
  id              String    @id @default(cuid())
  tenantId        String
  clientId        String
  watchId         String
  stage           DealStage @default(LEAD)
  expectedCloseAt DateTime?
  agreedPrice      Decimal   @db.Decimal(12, 2)
  originalCurrency String?
  originalAmount   Decimal?  @db.Decimal(12, 2)
  exchangeRate     Decimal?  @db.Decimal(12, 6)
  notes            String?
  deletedAt        DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant                Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client                Client                 @relation(fields: [clientId], references: [id], onDelete: Restrict)
  watch                 Watch                  @relation(fields: [watchId], references: [id], onDelete: Restrict)
  payments              Payment[]
  operatingExpenses     OperatingExpense[]
  accountEntries        AccountEntry[]
  storefrontReservation StorefrontReservation?

  @@index([tenantId])
  @@index([tenantId, stage])
  @@index([tenantId, clientId])
  @@index([tenantId, watchId])
  @@index([tenantId, deletedAt])
  @@map("deals")
}

model Payment {
  id        String        @id @default(cuid())
  tenantId  String
  dealId    String
  amount    Decimal       @db.Decimal(12, 2)
  method    PaymentMethod
  status    PaymentStatus @default(PENDING)
  dueDate   DateTime?
  paidAt    DateTime?
  notes     String?
  deletedAt DateTime?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  deal          Deal           @relation(fields: [dealId], references: [id], onDelete: Restrict)
  treasuryEntry TreasuryEntry?

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, method])
  @@index([tenantId, dealId])
  @@index([tenantId, deletedAt])
  @@map("payments")
}

model MatchSuggestion {
  id          String    @id @default(cuid())
  tenantId    String
  clientId    String
  watchId     String
  reason      String
  score       Int
  dismissedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  watch  Watch  @relation(fields: [watchId], references: [id], onDelete: Cascade)

  @@unique([tenantId, clientId, watchId])
  @@index([tenantId])
  @@index([clientId])
  @@index([watchId])
  @@index([tenantId, dismissedAt])
  @@map("match_suggestions")
}

model AutomationRule {
  id            String             @id @default(cuid())
  tenantId      String
  type          AutomationRuleType
  isEnabled     Boolean            @default(true)
  thresholdDays Int
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  tenant Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  runs   AutomationRun[]

  @@unique([tenantId, type])
  @@index([tenantId])
  @@index([tenantId, type])
  @@index([tenantId, isEnabled])
  @@map("automation_rules")
}

model AutomationRun {
  id           String              @id @default(cuid())
  tenantId     String
  ruleId       String
  status       AutomationRunStatus
  resultCount  Int
  errorMessage String?
  createdAt    DateTime            @default(now())

  tenant Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  rule   AutomationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([ruleId])
  @@map("automation_runs")
}

model OperatingExpense {
  id          String                   @id @default(cuid())
  tenantId    String
  dealId      String?
  category    OperatingExpenseCategory
  amount      Decimal                  @db.Decimal(12, 2)
  notes       String?
  expenseDate DateTime                 @db.Date
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt

  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  deal           Deal?          @relation(fields: [dealId], references: [id], onDelete: SetNull)
  accountEntries AccountEntry[]

  @@index([tenantId])
  @@index([tenantId, category])
  @@index([tenantId, expenseDate])
  @@index([dealId])
  @@map("operating_expenses")
}

// --- AI Market Radar (tenant-scoped ingest + listings) ---

model Channel {
  id                String      @id @default(cuid())
  tenantId          String
  type              ChannelType
  name              String?
  externalChannelId String?
  isActive          Boolean     @default(true)
  metadata          Json?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  tenant       Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  radarImports RadarImport[]
  messages     ChannelMessage[]

  @@unique([tenantId, externalChannelId])
  @@index([tenantId])
  @@index([tenantId, type])
  @@index([tenantId, isActive])
  @@map("radar_channels")
}

model RadarImport {
  id               String       @id @default(cuid())
  tenantId         String
  channelId        String
  status           ImportStatus @default(PENDING)
  startedAt        DateTime?
  completedAt      DateTime?
  errorMessage     String?
  stats            Json?
  originalFileName String?
  fileSizeBytes    Int?
  sourceGroupName  String?
  dateRangeStart   DateTime?
  dateRangeEnd     DateTime?
  listingsCreated  Int          @default(0)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  tenant   Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  channel  Channel          @relation(fields: [channelId], references: [id], onDelete: Cascade)
  messages ChannelMessage[]

  @@index([tenantId])
  @@index([tenantId, channelId])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@map("radar_imports")
}

model ChannelMessage {
  id                   String               @id @default(cuid())
  tenantId             String
  channelId            String
  importId             String
  externalMessageId    String?
  content              String               @db.Text
  contentHash          String
  postedAt             DateTime?
  /// Reserved for live-channel ingestion (WhatsApp user ID, Telegram user ID, etc.). For .txt imports, use senderRaw instead. Null during V1.
  authorExternalId     String?
  rawPayload           Json?
  classificationStatus ClassificationStatus @default(PENDING)
  processedAt          DateTime?
  hasMedia             Boolean              @default(false)
  isSystemMessage      Boolean              @default(false)
  senderRaw            String
  createdAt            DateTime             @default(now())

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  channel       Channel        @relation(fields: [channelId], references: [id], onDelete: Cascade)
  import        RadarImport    @relation(fields: [importId], references: [id], onDelete: Cascade)
  marketListing MarketListing?

  @@unique([tenantId, contentHash])
  @@index([tenantId])
  @@index([tenantId, channelId])
  @@index([tenantId, importId])
  @@index([tenantId, postedAt])
  @@index([tenantId, channelId, postedAt])
  @@index([tenantId, createdAt])
  @@index([tenantId, classificationStatus])
  @@map("radar_channel_messages")
}

model Contact {
  id               String    @id @default(cuid())
  tenantId         String
  clientId         String?
  displayName      String?
  phone            String?
  email            String?
  telegramUsername String?
  telegramUserId   String?
  whatsappId       String?
  notes            String?
  metadata         Json?
  firstSeenAt      DateTime?
  lastSeenAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client         Client?         @relation(fields: [clientId], references: [id], onDelete: SetNull)
  marketListings MarketListing[]

  @@index([tenantId])
  @@index([tenantId, clientId])
  @@index([tenantId, phone])
  @@index([tenantId, email])
  @@index([tenantId, telegramUserId])
  @@index([tenantId, createdAt])
  @@map("radar_contacts")
}

model MarketListing {
  id                      String              @id @default(cuid())
  tenantId                String
  messageId               String              @unique
  contactId               String?
  watchReferenceId        String?
  intent                  MarketListingIntent @default(GENERAL_INQUIRY)
  reviewStatus            ReviewStatus        @default(PENDING_REVIEW)
  referenceSource         ExtractionSource?
  brand                   String?
  feedConfidence          Float?
  initialConfidence       Float?
  rawModelMention         String?
  referenceNumberExplicit String?
  aiSummary               String?
  urgencyDetected         Boolean             @default(false)
  conditionNotes          String?
  hasBox                  Boolean?
  hasPapers               Boolean?
  year                    Int?
  dealerNotes             String?
  confirmedBy             String?
  confirmedAt             DateTime?
  dismissedBy             String?
  dismissedAt             DateTime?
  deletedAt               DateTime?
  aiRawResponse           Json?
  title                   String?
  description             String?             @db.Text
  priceAmount             Decimal?            @db.Decimal(14, 2)
  priceCurrency           String?
  location                String?
  metadata                Json?
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  message        ChannelMessage  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  contact        Contact?        @relation(fields: [contactId], references: [id], onDelete: SetNull)
  watchReference WatchReference? @relation(fields: [watchReferenceId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, reviewStatus])
  @@index([tenantId, intent])
  @@index([tenantId, watchReferenceId])
  @@index([tenantId, contactId])
  @@index([tenantId, createdAt])
  @@index([tenantId, reviewStatus, createdAt])
  @@index([tenantId, reviewStatus, feedConfidence, createdAt])
  @@index([tenantId, brand, createdAt])
  @@index([tenantId, deletedAt])
  @@index([tenantId, priceAmount, intent])
  @@map("radar_market_listings")
}

/// Global watch reference catalog (not tenant-scoped).
model WatchReference {
  id                   String            @id @default(cuid())
  brand                String
  model                String
  reference            String
  catalogSource        CatalogDataSource @default(MANUAL_ENTRY)
  aliases              Json
  line                 String?
  approximateRetailUsd Decimal?          @db.Decimal(12, 2)
  discontinued         Boolean           @default(false)
  metadata             Json?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  marketListings MarketListing[]

  @@unique([brand, model, reference])
  @@index([brand])
  @@index([reference])
  @@index([brand, model])
  @@map("radar_watch_references")
}

// --- Capital de socios ---

model Investor {
  id              String   @id @default(cuid())
  tenantId        String
  name            String
  ownershipPercent Decimal  @db.Decimal(5, 2)
  isActive        Boolean  @default(true)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  tenant        Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contributions InvestorContribution[]
  distributions InvestorDistribution[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([tenantId, isActive])
  @@index([tenantId, deletedAt])
  @@map("investors")
}

model InvestorContribution {
  id           String         @id @default(cuid())
  tenantId     String
  investorId   String
  amount       Decimal        @db.Decimal(12, 2)
  account      CapitalAccount
  notes        String?
  contributedAt DateTime
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  deletedAt    DateTime?

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  investor      Investor       @relation(fields: [investorId], references: [id], onDelete: Restrict)
  treasuryEntry TreasuryEntry?

  @@index([tenantId])
  @@index([tenantId, investorId])
  @@index([tenantId, contributedAt])
  @@index([tenantId, deletedAt])
  @@map("investor_contributions")
}

model InvestorDistribution {
  id         String         @id @default(cuid())
  tenantId   String
  investorId String
  amount     Decimal        @db.Decimal(12, 2)
  account    CapitalAccount
  notes      String?
  paidAt     DateTime
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  deletedAt  DateTime?

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  investor      Investor       @relation(fields: [investorId], references: [id], onDelete: Restrict)
  treasuryEntry TreasuryEntry?

  @@index([tenantId])
  @@index([tenantId, investorId])
  @@index([tenantId, paidAt])
  @@index([tenantId, deletedAt])
  @@map("investor_distributions")
}

// --- Treasury (cash ledger) ---

model TreasuryEntry {
  id              String            @id @default(cuid())
  tenantId        String
  account         TreasuryAccount
  direction       TreasuryDirection
  amount          Decimal           @db.Decimal(12, 2)
  currency        Currency
  amountMxn       Decimal           @db.Decimal(12, 2)
  exchangeRate    Decimal?          @db.Decimal(12, 6)
  transactionDate DateTime
  description     String?

  accountPaymentId String? @unique
  dealPaymentId    String? @unique
  contributionId   String? @unique
  distributionId   String? @unique

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  tenant         Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  accountPayment AccountPayment?       @relation(fields: [accountPaymentId], references: [id], onDelete: SetNull)
  dealPayment    Payment?              @relation(fields: [dealPaymentId], references: [id], onDelete: SetNull)
  contribution   InvestorContribution? @relation(fields: [contributionId], references: [id], onDelete: SetNull)
  distribution   InvestorDistribution? @relation(fields: [distributionId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, account])
  @@index([tenantId, account, direction])
  @@index([tenantId, transactionDate])
  @@index([tenantId, deletedAt])
  @@map("treasury_entries")
}

// --- Cuentas (AR/AP) ---

model AccountEntry {
  id               String               @id @default(cuid())
  tenantId         String
  type             AccountEntryType
  status           AccountEntryStatus   @default(OPEN)
  category         AccountEntryCategory @default(OTHER)
  source           AccountEntrySource   @default(MANUAL)
  counterpartyName String
  counterpartyType CounterpartyType     @default(OTHER)
  concept          String
  totalAmount      Decimal              @db.Decimal(12, 2)
  currency         Currency             @default(MXN)
  exchangeRate     Decimal?             @db.Decimal(12, 6)
  reference        String?
  issuedAt         DateTime?
  dueDate          DateTime?
  closedAt         DateTime?
  notes            String?

  clientId  String?
  dealId    String?
  watchId   String?
  expenseId String?

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  tenant   Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client   Client?            @relation(fields: [clientId], references: [id], onDelete: SetNull)
  deal     Deal?              @relation(fields: [dealId], references: [id], onDelete: SetNull)
  watch    Watch?             @relation(fields: [watchId], references: [id], onDelete: SetNull)
  expense  OperatingExpense?  @relation(fields: [expenseId], references: [id], onDelete: SetNull)
  payments AccountPayment[]

  @@index([tenantId])
  @@index([tenantId, type])
  @@index([tenantId, status])
  @@index([tenantId, type, status])
  @@index([tenantId, source])
  @@index([tenantId, dueDate])
  @@index([tenantId, clientId])
  @@index([tenantId, dealId])
  @@index([tenantId, deletedAt])
  @@index([tenantId, createdAt])
  @@map("account_entries")
}

model AccountPayment {
  id               String            @id @default(cuid())
  tenantId         String
  entryId          String
  amount           Decimal           @db.Decimal(12, 2)
  currency         Currency          @default(MXN)
  method           PaymentMethod
  paidAt           DateTime
  notes            String?
  cashAccount      TreasuryAccount?
  exchangeRateUsed Decimal?          @db.Decimal(12, 6)
  deletedAt        DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  entry         AccountEntry   @relation(fields: [entryId], references: [id], onDelete: Cascade)
  treasuryEntry TreasuryEntry?

  @@index([tenantId])
  @@index([entryId])
  @@index([tenantId, entryId])
  @@index([tenantId, paidAt])
  @@index([tenantId, deletedAt])
  @@map("account_payments")
}

// --- Storefront ---

model StorefrontReservation {
  id       String @id @default(cuid())
  tenantId String
  watchId  String
  clientId String?

  customerName  String
  customerEmail String
  customerPhone String?

  stripeCheckoutSessionId String  @unique
  stripePaymentIntentId   String? @unique

  reservationAmount    Decimal @db.Decimal(12, 2)
  currency             String  @default("mxn")

  status               StorefrontReservationStatus @default(PENDING)
  webhookEventId       String?
  reservationExpiresAt DateTime?
  processedAt          DateTime?
  expiredAt            DateTime?
  cancelledAt          DateTime?

  dealId String? @unique

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  tenant Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  watch  Watch    @relation(fields: [watchId], references: [id], onDelete: Restrict)
  client Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  deal   Deal?    @relation(fields: [dealId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, watchId])
  @@index([tenantId, customerEmail])
  @@index([tenantId, createdAt])
  @@index([tenantId, deletedAt])
  @@map("storefront_reservations")
}

// --- Data onboarding (staging only — never writes operational tables in Phase 1) ---

model DataImportSession {
  id              String           @id @default(cuid())
  tenantId        String           @map("tenant_id")
  createdByUserId String           @map("created_by_user_id")
  status          DataImportStatus @default(CREATED)
  title           String?
  totalFiles      Int              @default(0) @map("total_files")
  processedFiles  Int              @default(0) @map("processed_files")
  totalRows       Int              @default(0) @map("total_rows")
  validRows       Int              @default(0) @map("valid_rows")
  warningRows     Int              @default(0) @map("warning_rows")
  invalidRows     Int              @default(0) @map("invalid_rows")
  importedRows    Int              @default(0) @map("imported_rows")
  dryRunVersion   String?          @map("dry_run_version")
  importStartedAt DateTime?        @map("import_started_at")
  startedAt       DateTime?        @map("started_at")
  completedAt     DateTime?        @map("completed_at")
  errorMessage    String?          @map("error_message")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  tenant    Tenant             @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  createdBy User               @relation("DataImportCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  files     DataImportFile[]
  records   DataImportRecord[]
  events    DataImportEvent[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@map("data_import_sessions")
}

model DataImportFile {
  id                 String               @id @default(cuid())
  tenantId           String               @map("tenant_id")
  sessionId          String               @map("session_id")
  originalFilename   String               @map("original_filename")
  storageKey         String               @map("storage_key")
  mimeType           String               @map("mime_type")
  fileType           DataImportFileType   @map("file_type")
  byteSize           Int                  @map("byte_size")
  checksum           String?
  status             DataImportFileStatus @default(UPLOADED)
  detectedEntityType DataImportEntityType @default(UNKNOWN) @map("detected_entity_type")
  sheetNames         Json?                @map("sheet_names")
  rowCount           Int                  @default(0) @map("row_count")
  classificationMeta Json?                @map("classification_meta")
  fieldMapping          Json?                @map("field_mapping")
  mappingVersion        String?              @map("mapping_version")
  extractionProvider    String?              @map("extraction_provider")
  extractionModel       String?              @map("extraction_model")
  extractedDocumentData Json?                @map("extracted_document_data")
  extractionError       String?              @map("extraction_error")
  errorMessage          String?              @map("error_message")
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @updatedAt @map("updated_at")

  tenant  Tenant             @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  session DataImportSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  records DataImportRecord[]

  @@index([tenantId])
  @@index([sessionId])
  @@index([tenantId, sessionId])
  @@index([status])
  @@map("data_import_files")
}

model DataImportRecord {
  id                 String                    @id @default(cuid())
  tenantId           String                    @map("tenant_id")
  sessionId          String                    @map("session_id")
  fileId             String                    @map("file_id")
  entityType         DataImportEntityType      @default(UNKNOWN) @map("entity_type")
  sourceSheet        String?                   @map("source_sheet")
  sourceRowNumber    Int?                      @map("source_row_number")
  rawData            Json                      @map("raw_data")
  normalizedData     Json?                     @map("normalized_data")
  validationErrors   Json?                     @map("validation_errors")
  validationWarnings Json?                     @map("validation_warnings")
  isValid            Boolean                   @default(true) @map("is_valid")
  isSelected         Boolean                   @default(true) @map("is_selected")
  duplicateKey       String?                   @map("duplicate_key")
  duplicateStatus    DataImportDuplicateStatus @default(NONE) @map("duplicate_status")
  importStatus       DataImportRecordStatus    @default(STAGED) @map("import_status")
  targetRecordId     String?                   @map("target_record_id")
  createdAt          DateTime                  @default(now()) @map("created_at")
  updatedAt          DateTime                  @updatedAt @map("updated_at")

  tenant  Tenant            @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  session DataImportSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  file    DataImportFile    @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([sessionId])
  @@index([fileId])
  @@index([tenantId, sessionId])
  @@index([entityType])
  @@index([tenantId, entityType])
  @@index([importStatus])
  @@map("data_import_records")
}

model DataImportEvent {
  id        String              @id @default(cuid())
  tenantId  String              @map("tenant_id")
  sessionId String              @map("session_id")
  eventType DataImportEventType @map("event_type")
  message   String
  metadata  Json?
  createdAt DateTime            @default(now()) @map("created_at")

  tenant  Tenant            @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  session DataImportSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([sessionId])
  @@index([tenantId, sessionId])
  @@index([tenantId, createdAt])
  @@map("data_import_events")
}
